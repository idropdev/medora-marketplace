# =============================================================================
# Medora Marketplace — Environment Variables Template
# =============================================================================
# Copy this file to .env.local (never commit .env.local) and fill in the values.
#
#   cp .env.example .env.local
#
# -----------------------------------------------------------------------------
# FRONTEND KEYS  (bundled into client-side JS by Vite — use VITE_ prefix)
# These are safe to expose in the browser *only* when:
#   • Google Maps API key has HTTP referrer restrictions set in Google Cloud Console
#   • Supabase anon key is paired with Row Level Security (RLS) policies on every table
# -----------------------------------------------------------------------------

# Google Maps JavaScript API (also needs Places API + Geocoding enabled in Cloud Console)
# → https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=

# Supabase project URL and anon (public) key
# → https://supabase.com/dashboard/project/<your-project>/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# SERVER-ONLY KEYS  (never use VITE_ prefix — must stay out of the browser bundle)
# Only used by scripts run locally or in CI (e.g. seed-providers.ts)
# -----------------------------------------------------------------------------

# Supabase service-role key (bypasses RLS — NEVER expose to the browser)
# → https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_SERVICE_ROLE_KEY=
